{
  "name": "nova-ai-monitor",
  "version": "2.0.0",
  "description": "Nova AI - AI Employee Management Platform",
  "main": "main.js",
  "author": "Nova AI Team",
  "license": "MIT",
  "scripts": {
    "electron:build": "electron-builder --mac --win"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.novaai.monitor",
    "productName": "Nova AI Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "../web/dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
